---
/* =========================================================
   Project Card Props
   ========================================================= */

interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  images?: string[];
  tags?: string[];

  /*
    These optional settings allow the image display to be
    adjusted separately for each project.
  */
  imageFit?: "cover" | "contain";
  imagePosition?: string;
}

/* =========================================================
   Pull values from Astro.props
   ========================================================= */

const {
  title,
  description,
  href,
  image,
  images = [],
  tags = [],
  imageFit = "cover",
  imagePosition = "center",
} = Astro.props;

/* =========================================================
   Image handling
   ========================================================= */

const galleryImages = images.length > 0 ? images : image ? [image] : [];
---

<!-- =======================================================
     Project card wrapper
     ======================================================= -->

<a class="project-card" href={href}>

  <!-- =====================================================
       Image area
       ===================================================== -->

  {galleryImages.length > 0 && (
    <div
      class={
        galleryImages.length > 1
          ? `image-gallery count-${Math.min(galleryImages.length, 3)}`
          : "single-image"
      }
    >
      {galleryImages.slice(0, 3).map((src, index) => (
        <div class={`image-wrap image-${index + 1}`}>
          <img
            src={src}
            alt={`${title} project image ${index + 1}`}
            loading="lazy"
            style={`object-fit: ${imageFit}; object-position: ${imagePosition};`}
          />
        </div>
      ))}
    </div>
  )}

  <!-- =====================================================
       Text content
       ===================================================== -->

  <div class="card-content">
    <h2>{title}</h2>

    <p>{description}</p>

    <!-- ===================================================
         Project tags
         =================================================== -->

    {tags.length > 0 && (
      <ul class="tags">
        {tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )}
  </div>
</a>

<style>
  /* =======================================================
     Card container
     ======================================================= */

  .project-card {
    display: block;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--bg-card);
    color: inherit;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    background: var(--bg-card-hover);
    box-shadow: 0 0 24px var(--accent-glow);
  }

  /* =======================================================
     Single image layout
     ======================================================= */

  .single-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-main);
  }

  /* =======================================================
     Multi-image gallery layout
     ======================================================= */

  .image-gallery {
    display: grid;
    gap: 0.35rem;
    padding: 0.35rem;
    aspect-ratio: 16 / 6;
    background: var(--bg-main);
  }

  .image-gallery.count-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .image-gallery.count-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .image-wrap {
    height: 100%;
    overflow: hidden;
    border-radius: 0.65rem;
    background: var(--bg-main);
  }

  /* =======================================================
     Image display
     ======================================================= */

  .image-wrap img,
  .single-image img {
    display: block;
    width: 100%;
    height: 100%;

    /*
      These provide sensible defaults if no project-specific
      settings are supplied.
    */
    object-fit: cover;
    object-position: center;
  }

  /* =======================================================
     Card text content
     ======================================================= */

  .card-content {
    padding: 1rem;
  }

  h2 {
    margin: 0 0 0.5rem;
    color: var(--text-main);
    font-size: 1.15rem;
  }

  p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* =======================================================
     Tags
     ======================================================= */

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.75rem;
  }
</style>