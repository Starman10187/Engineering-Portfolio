---
/* =========================================================
   Project media grid

   Supports:
   - images
   - short project videos
   - grid layout
   - masonry layout
   - stack layout

   layout controls the page arrangement.
   kind controls whether an item is an image or a video.

   Example:
   layout="grid"
   kind: "video"
   ========================================================= */

interface ProjectImage {
  kind?: "image";
  src: string;
  alt: string;
  caption?: string;
}

interface ProjectVideo {
  kind: "video";
  src: string;
  alt?: string;
  caption?: string;
  poster?: string;
  controls?: boolean;
  mimeType?: string;
}

type ProjectMedia = ProjectImage | ProjectVideo;

interface Props {
  media: ProjectMedia[];
  layout?: "grid" | "masonry" | "stack" | "feature-right" | "feature-left";
  uniform?: boolean;
}

const {
  media,
  layout = "grid",
  uniform = false,
} = Astro.props;
---

<div class={`project-media-grid is-${layout} ${uniform ? "is-uniform" : ""}`}>
  {media.map((item) => (
    <figure class={`media-card ${item.kind === "video" ? "has-video" : "has-image"}`}>
      <div class="media-frame">
        {item.kind === "video" ? (
          <video
            class="media-content"
            autoplay={!item.controls}
            muted
            loop={!item.controls}
            playsinline
            preload="metadata"
            poster={item.poster}
            controls={item.controls}
            aria-label={item.alt}
          >
            <source src={item.src} type={item.mimeType ?? "video/mp4"} />
          </video>
        ) : (
          <img
            class="media-content"
            src={item.src}
            alt={item.alt}
            loading="lazy"
            decoding="async"
          />
        )}
      </div>

      {item.caption && (
        <figcaption>
          {item.caption}
        </figcaption>
      )}
    </figure>
  ))}
</div>

<style>
  /* =======================================================
     Base layout
     ======================================================= */

  .project-media-grid {
    margin: 1.5rem 0;
  }

  .media-card {
    margin: 0;
  }

  /* =======================================================
     Grid layout
     ======================================================= */

  .project-media-grid.is-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  /* =======================================================
     Masonry layout
     ======================================================= */

  .project-media-grid.is-masonry {
    display: block;
    column-count: 2;
    column-gap: 1.25rem;
  }

  .project-media-grid.is-masonry .media-card {
    display: inline-block;
    width: 100%;
    margin: 0 0 1.25rem;
    break-inside: avoid;
  }

  /* =======================================================
     Stack layout
     ======================================================= */

  .project-media-grid.is-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* =======================================================
   Feature right layout

   Used when two smaller images should stack on the left
   and one taller image should sit on the right.
   ======================================================= */

.project-media-grid.is-feature-right {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  grid-template-rows: repeat(2, minmax(0, 1fr));
  gap: 1.25rem;
  align-items: stretch;
}

.project-media-grid.is-feature-right .media-card {
  min-width: 0;
}

.project-media-grid.is-feature-right .media-card:nth-child(1) {
  grid-column: 1;
  grid-row: 1;
}

.project-media-grid.is-feature-right .media-card:nth-child(2) {
  grid-column: 1;
  grid-row: 2;
}

.project-media-grid.is-feature-right .media-card:nth-child(3) {
  grid-column: 2;
  grid-row: 1 / span 2;
}

.project-media-grid.is-feature-right .media-frame {
  height: 100%;
}

.project-media-grid.is-feature-right .media-content {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.project-media-grid.is-feature-right .media-card:nth-child(1),
.project-media-grid.is-feature-right .media-card:nth-child(2),
.project-media-grid.is-feature-right .media-card:nth-child(3) {
  display: flex;
  flex-direction: column;
}

.project-media-grid.is-feature-right .media-card:nth-child(1) .media-frame,
.project-media-grid.is-feature-right .media-card:nth-child(2) .media-frame {
  aspect-ratio: 16 / 9;
}

.project-media-grid.is-feature-right .media-card:nth-child(3) .media-frame {
  flex: 1;
}

/* =======================================================
   Feature left layout

   Used when one taller image should sit on the left
   and two smaller images should stack on the right.
   ======================================================= */

.project-media-grid.is-feature-left {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  grid-template-rows: repeat(2, minmax(0, 1fr));
  gap: 1.25rem;
  align-items: stretch;
}

.project-media-grid.is-feature-left .media-card {
  min-width: 0;
}

.project-media-grid.is-feature-left .media-card:nth-child(1) {
  grid-column: 1;
  grid-row: 1 / span 2;
}

.project-media-grid.is-feature-left .media-card:nth-child(2) {
  grid-column: 2;
  grid-row: 1;
}

.project-media-grid.is-feature-left .media-card:nth-child(3) {
  grid-column: 2;
  grid-row: 2;
}

.project-media-grid.is-feature-left .media-frame {
  height: 100%;
}

.project-media-grid.is-feature-left .media-content {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.project-media-grid.is-feature-left .media-card:nth-child(1),
.project-media-grid.is-feature-left .media-card:nth-child(2),
.project-media-grid.is-feature-left .media-card:nth-child(3) {
  display: flex;
  flex-direction: column;
}

.project-media-grid.is-feature-left .media-card:nth-child(1) .media-frame {
  flex: 1;
}

.project-media-grid.is-feature-left .media-card:nth-child(2) .media-frame,
.project-media-grid.is-feature-left .media-card:nth-child(3) .media-frame {
  aspect-ratio: 16 / 9;
}

  /* =======================================================
     Media styling
     ======================================================= */

  .media-frame {
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--accent-soft, rgba(255, 255, 255, 0.12));
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .media-content {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
  }

  video.media-content {
    background: #000;
  }

  /*
    Uniform mode is useful when placing a video and image
    side by side because it forces both items to the same
    visual shape.
  */

  .project-media-grid.is-uniform .media-frame {
    aspect-ratio: 4 / 3;
  }

  .project-media-grid.is-uniform .media-content {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* =======================================================
     Caption styling
     ======================================================= */

  .media-card figcaption {
    margin-top: 0.45rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* =======================================================
     Mobile layout
     ======================================================= */

  @media (max-width: 700px) {
  .project-media-grid.is-grid {
    grid-template-columns: 1fr;
  }

  .project-media-grid.is-masonry {
    column-count: 1;
  }

  .project-media-grid.is-feature-right {
    grid-template-columns: 1fr;
    grid-template-rows: auto;
  }

  .project-media-grid.is-feature-right .media-card:nth-child(1),
  .project-media-grid.is-feature-right .media-card:nth-child(2),
  .project-media-grid.is-feature-right .media-card:nth-child(3) {
    grid-column: auto;
    grid-row: auto;
  }

  .project-media-grid.is-feature-right .media-frame {
    height: auto;
  }

  .project-media-grid.is-feature-right .media-content {
    height: auto;
  }

  .project-media-grid.is-feature-left {
  grid-template-columns: 1fr;
  grid-template-rows: auto;
}

.project-media-grid.is-feature-left .media-card:nth-child(1),
.project-media-grid.is-feature-left .media-card:nth-child(2),
.project-media-grid.is-feature-left .media-card:nth-child(3) {
  grid-column: auto;
  grid-row: auto;
}

.project-media-grid.is-feature-left .media-frame {
  height: auto;
}

.project-media-grid.is-feature-left .media-content {
  height: auto;
}

  }
</style>