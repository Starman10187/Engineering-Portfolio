---
import Layout from "../../layouts/Layout.astro";
import ProjectMediaGrid from "../../components/ProjectPageTemplating/ProjectMediaGrid.astro";
---

<Layout title="Warman Design & Build Challenge | Simon Portfolio">
  <article class="project-page">
    <a class="back-link" href="/#projects">← Back to Projects Overview</a>

    <h1>Warman Design & Build Challenge</h1>

    <p class="intro">
      This page will contain the detailed write-up for the Audio Mixer project.
    </p>

    <section>
      <h2>Project Overview</h2>
      <p>
        Add a short explanation of what the project is, why you built it, and what problem it solves.
      </p>
    </section>

    <section>
      <h2>Key Features</h2>
      <ul>
        <li>Feature or design point one.</li>
        <li>Feature or design point two.</li>
        <li>Feature or design point three.</li>
      </ul>
    </section>

    <section>
      <h2>Tools and Technologies</h2>
      <p>
        Add the main tools, software, hardware, or methods used in this project.
      </p>
    </section>

    <section>
      <h2>Project Outcome</h2>
      <p>
        Add what you achieved, tested, learned, or would improve next.
      </p>
    </section>
  </article>
</Layout>

<style>
  .project-page {
    max-width: 900px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--accent);
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  h1 {
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--accent);
    font-size: 2.5rem;
  }

  .intro {
    max-width: 760px;
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  section {
    margin-top: 2.5rem;
  }

  h2 {
    color: var(--text-main);
    margin-bottom: 0.75rem;
  }

  p,
  li {
    color: var(--text-muted);
    line-height: 1.7;
  }
</style>