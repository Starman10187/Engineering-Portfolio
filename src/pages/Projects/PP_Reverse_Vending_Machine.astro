---
import Layout from "../../layouts/Layout.astro";
import WorkInProgress from "../../components/ProjectPageTemplating/WorkInProgress.astro";
---

<Layout title="Reverse Vending Machine | Simon Portfolio">
  <article class="project-page">
    <a class="back-link" href="/#projects">
      ← Back to Projects Overview
    </a>

    <h1>Reverse Vending Machine</h1>

    <WorkInProgress
      message="This project page is currently being documented."
    />

  
  </article>
</Layout>

<style>
  .project-page {
    max-width: 900px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--accent);
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  h1 {
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--accent);
    font-size: 2.5rem;
  }
</style>