---
/* =========================================================
   Imports
   ========================================================= */

/*
  Layout wraps the page with the shared site structure,
  including your sidebar and main content area.
*/
import Layout from "../layouts/Layout.astro";

/*
  ProjectCard is the reusable card component used for each
  project in the projects overview section.
*/
import ProjectCard from "../components/MainPageTemplating/ProjectCard.astro";

/*
  Central project data.

  This file feeds both the homepage project cards
  and the sidebar project links.

  Current expected location:
  src/data/Projects.ts
*/
import { projects } from "../data/Projects";

/*
  Friends website links.

  To add another friend, duplicate one of the objects below
  and update the name, description, and href.
*/
const friends = [
  {
    name: "Julian Cooper | Mechatronics Engineering",
    description: "Mechatronics Maestro",
    href: "https://jlrpcrobotics.site/",
  },
  {
    name: "Zack Harvey | Mechatronics Engineering",
    description: "A Distinguised Roboticist",
    href: "https://zackharvey.com/",
  },
];
---

<Layout title="Simon Portfolio">

  <!-- =====================================================
       About Section
       This is the landing section linked from /#about
       ===================================================== -->

  <section id="about" class="about-section">
    <div class="profile-heading">
      <h1>Simon Finn</h1>

      <p class="profile-tagline">
        Curious tinkerer, practical problem-solver
      </p>
    </div>

    <div class="about-copy">
      <p>
        I’m a mechatronics engineering graduate who enjoys figuring out how
        things work, building practical systems, and learning through hands-on
        experimentation.
      </p>

      <p>
        My projects have taken me from machine-vision recycling equipment and
        water leak detection to robotics, embedded electronics, and a slightly
        over-engineered home server. I’m particularly interested in water,
        agriculture, food manufacturing, and recycling, where thoughtful
        engineering can make everyday work safer, simpler, and more efficient.
      </p>
    </div>

    <a
      class="linkedin-link"
      href="https://www.linkedin.com/in/simonfinnengineering/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Visit Simon Finn's LinkedIn profile"
    >
      <span class="linkedin-mark" aria-hidden="true">in</span>
      <span>LinkedIn Profile</span>
      <span class="external-arrow" aria-hidden="true">↗</span>
    </a>
  </section>

  <!-- =====================================================
       Projects Overview Section
       This is the section linked from /#projects.
       The sidebar item "Projects Overview" points here.
       ===================================================== -->

  <section id="projects" class="projects-section">
    <h1>Projects Overview</h1>

    <p>
      A selection of engineering, embedded systems, automation, and prototype
      development projects.
    </p>

    <!-- ===================================================
      Project Card Grid

      These cards are automatically generated from:
      src/data/Projects.ts

      To add, remove, rename, reorder, or adjust project
      images, edit the projects array in that file.
      =================================================== -->

    <div class="project-grid">
      {projects.map((project) => (
        <ProjectCard
          title={project.title}
          description={project.description}
          href={project.href}
          images={project.images}
          tags={project.tags}
          imageFit={project.imageFit}
          imagePosition={project.imagePosition}
        />
      ))}
    </div>
  </section>

  <!-- =====================================================
       Friends Websites Section
       This section is nested below the projects overview.
       ===================================================== -->

  <section id="friends" class="friends-section">
    <h1>Friends' Websites</h1>

    <p>
      Please check out my fellow friends websites also!
    </p>

    <div class="friends-grid">
      {friends.map((friend) => (
        <a
          class="friend-card"
          href={friend.href}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div>
            <h2>{friend.name}</h2>
            <p>{friend.description}</p>
          </div>

          <span>Visit website →</span>
        </a>
      ))}
    </div>
  </section>

</Layout>

<style>
  /* =======================================================
     Shared section spacing
     ======================================================= */

  section {
    padding-bottom: 4rem;
  }

  /* =======================================================
     About section
     ======================================================= */

  .about-section {
    min-height: auto;
    padding-bottom: 2.5rem;
  }

  .profile-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: 1rem;
    row-gap: 0.25rem;
    margin-bottom: 1rem;
  }

  .profile-heading h1 {
    margin-bottom: 0;
  }

  .about-section .profile-tagline {
    max-width: none;
    margin: 0;
    color: var(--text-muted);
    font-size: 1rem;
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .about-copy {
    max-width: 780px;
  }

  .about-section .about-copy p {
    max-width: 780px;
    margin-top: 0;
    margin-bottom: 0.9rem;
    color: var(--text-muted);
    font-size: 1.15rem;
  }

  /* =======================================================
     LinkedIn profile link
     ======================================================= */

  .linkedin-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.35rem;
    padding: 0.55rem 0.8rem;

    border: 1px solid var(--border-subtle);
    border-radius: 0.6rem;

    background: var(--surface-card);
    color: var(--accent);

    font-weight: 600;
    text-decoration: none;

    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .linkedin-link:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .linkedin-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .linkedin-mark {
    display: inline-flex;
    width: 1.35rem;
    height: 1.35rem;
    align-items: center;
    justify-content: center;

    border: 1px solid currentColor;
    border-radius: 0.2rem;

    font-family: Arial, sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1;
  }

  .external-arrow {
    font-size: 0.9rem;
  }

  /* =======================================================
     Projects overview section
     ======================================================= */

  .projects-section {
    padding-top: 1rem;
  }

  .projects-section > p {
    max-width: 760px;
  }

  /* =======================================================
     Friends websites section
     ======================================================= */

  .friends-section {
    padding-top: 1rem;
  }

  .friends-section > p {
    max-width: 760px;
  }

  .friends-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 1100px;
    margin-top: 1.5rem;
  }

  .friend-card {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem;
    border: 1px solid var(--border-subtle);
    border-radius: 1rem;
    background: var(--surface-card);
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .friend-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
  }

  .friend-card h2 {
    margin: 0 0 0.5rem;
    color: var(--text-main);
    font-size: 1.3rem;
  }

  .friend-card p {
    max-width: 700px;
    margin: 0;
  }

  .friend-card span {
    flex-shrink: 0;
    align-self: center;
    color: var(--accent);
    font-weight: 600;
    white-space: nowrap;
  }

  /* =======================================================
     Headings
     ======================================================= */

  h1 {
    margin-top: 0;
    margin-bottom: 0.75rem;
    color: var(--text-main);
    font-size: 2.5rem;
  }

  .about-section h1,
  .projects-section h1,
  .friends-section h1 {
    color: var(--accent);
  }

  /* =======================================================
     Paragraph text
     ======================================================= */

  p {
    max-width: 700px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* =======================================================
     Project card layout
     ======================================================= */

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 1100px;
    margin-top: 1.5rem;
  }

  /* =======================================================
     Mobile layout
     ======================================================= */

  @media (max-width: 700px) {
    .profile-heading {
      flex-direction: column;
      align-items: flex-start;
    }

    .friend-card {
      flex-direction: column;
    }

    .friend-card span {
      align-self: flex-start;
    }
  }
</style>